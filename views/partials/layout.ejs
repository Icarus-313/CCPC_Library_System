<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | CCPC Library</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-mark">CC</div>
        <div class="brand-text">
          <strong>CCPC Library</strong>
          <span>Inventory System</span>
        </div>
      </div>
      <nav>
        <a href="/" class="<%= active === 'dashboard' ? 'active' : '' %>">Dashboard</a>
        <a href="/books" class="<%= active === 'books' ? 'active' : '' %>">Books</a>
        <a href="/students" class="<%= active === 'students' ? 'active' : '' %>">Students</a>
        <a href="/borrow" class="<%= active === 'borrow' ? 'active' : '' %>">Active Borrows</a>
        <a href="/borrow/requests" class="<%= active === 'requests' ? 'active' : '' %>">
          Requests<% if (typeof pendingRequestCount !== 'undefined' && pendingRequestCount > 0) { %> <span class="nav-badge"><%= pendingRequestCount %></span><% } %>
        </a>
        <a href="/borrow/history" class="<%= active === 'history' ? 'active' : '' %>">Borrow History</a>
      </nav>
      <div class="sidebar-footer">
        <div class="signed-in-as">Signed in as<br><strong><%= adminUsername %></strong></div>
        <form method="POST" action="/auth/admin/logout">
          <button class="btn btn-outline btn-sm" type="submit" style="width:100%;">Log Out</button>
        </form>
      </div>
    </aside>
    <main class="content">
      <%- body %>
    </main>
  </div>
</body>
</html>
